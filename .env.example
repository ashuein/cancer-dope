# ====================== Application ======================
APP_NAME=PrecisionOncology
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# ====================== Database ======================
DATABASE_URL=sqlite+aiosqlite:///./data/metadata.db

# ====================== Paths ======================
DATA_ROOT=./data
UPLOAD_DIR=./data/uploads
CACHE_DIR=./data/cache
REFERENCE_DIR=./data/reference

# ====================== API Server ======================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
CORS_ORIGINS=["http://localhost:5173"]

# ====================== External APIs ======================
# AlphaFold3 Server (20 jobs/day free tier)
ALPHAFOLD_SERVER_URL=https://alphafoldserver.com
AF3_DAILY_LIMIT=20

# HuggingFace (ESMFold inference)
HF_API_TOKEN=

# Public APIs (no auth required, configurable base URLs)
REACTOME_BASE_URL=https://reactome.org/ContentService
CHEMBL_BASE_URL=https://www.ebi.ac.uk/chembl/api/data
DGIDB_BASE_URL=https://dgidb.org/api/graphql
GTEX_BASE_URL=https://gtexportal.org/api/v2
PKCSM_BASE_URL=http://biosig.lab.uq.edu.au/pkcsm
ENSEMBL_VEP_URL=https://rest.ensembl.org

# ====================== Tool Paths ======================
# NetMHCpan 4.1 (academic license, manual install)
NETMHCPAN_PATH=

# ====================== Module Flags ======================
# Set to false to disable specific modules
MODULE_TIMELINE=true
MODULE_TRACK1=true
MODULE_TRACK2=true
MODULE_BULK_RNA=true
MODULE_SCRNA=true
MODULE_GSEA=true
MODULE_CNV=true
MODULE_BAM=true
MODULE_IMAGING=true
MODULE_SPATIAL=true

# ====================== Rate Limits ======================
API_RATE_LIMIT=100
API_RATE_WINDOW=60

# ====================== Artifact Settings ======================
MAX_UPLOAD_SIZE_MB=500
ARTIFACT_RETENTION_DAYS=90
